# Copy to ".env" in the repo root (gitignored) and fill in credentials.
# Optional: create ".env" inside the app userData folder (Electron → app.getPath("userData")).
# That file loads second and overrides the repo .env (handy for packaged apps).
#
# GCS_BUCKET: omit to use defaults — `screen-record-dev` when running from source,
# `screen-record` when running the packaged app. electron-builder does not bundle
# repo `.env`, so the DMG still gets the prod default unless you set GCS_BUCKET
# in userData `.env` or in the process environment.

# GCS_BUCKET=screen-record
# Absolute path to your GCP service account JSON (or leave unset and use ADC).
GOOGLE_APPLICATION_CREDENTIALS=

GCS_OBJECT_PREFIX=recordings
GCS_SIGNED_URL_DAYS=90
