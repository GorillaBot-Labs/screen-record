generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Recording {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  gcsObjectName String   @unique
  publicUrl     String
  createdAt     DateTime @default(now())
  title         String?
  notes         String?

  @@map("recordings")
}
