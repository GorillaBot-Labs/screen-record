# Environment variables declared in this file are automatically made available to Prisma.
# See: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See: https://pris.ly/d/connection-strings

# Copy to `.env`. Use the exact connection string from Atlas (Connect → Drivers):
# host must include the deployment id, e.g. cluster0.ab12cd.mongodb.net — not "cluster0.mongodb.net".
# If SRV/DNS fails on your network (errors mentioning ".lan"), remove DNS "Search Domains" in
# macOS Network settings, or switch Atlas to the "Standard connection string" (mongodb://...).
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster0.v8ch8qb.mongodb.net/DATABASE?retryWrites=true&w=majority&appName=Cluster0"

# One-time backfill: `npm run reconcile -w screen-record-web` (see scripts/reconcile-recordings.ts).
# Same bucket as desktop uploads; default name matches desktop.
GCS_BUCKET="screen-record"

# GCP auth for listing the bucket (pick one):
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"
# Or paste JSON for a key that can list objects on the bucket:
# GCP_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# The same credentials are used by the gallery “delete” action (needs storage.objects.delete).
